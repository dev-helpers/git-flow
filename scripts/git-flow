#!/usr/bin/env bash
#
# See show_help above for more info
#
set -euo pipefail

show_help() {
	cat <<EOF
Usage: git-flow <command> [args]

Commands:
  sync        Sync current branch with its base (feature/bugfix → develop or hotfix → main)
  feature     Create a new feature branch (from develop)
  hotfix      Create a new hotfix branch (from main)
  bugfix      Create a new bugfix branch (from develop)
  propose     Open PR for current branch in Azure DevOps

Options:
  --push      Push the branch after creating/syncing
  --help      Show this help message

Example Usage:
  git sync
  git feature login
  git bugfix issue-123 --push
  git pr
EOF
}

# --- Configuration ---
BRANCH_TYPES="feature bugfix hotfix"

# --- Shared Functions ---
error() {
	printf '❌ Error: %s\n' "$1" >&2
	exit 1
}
warn() { printf ' ! Warning: %s\n' "$1" >&2; }
info() { printf ' → %s\n' "$1" >&2; }
ok() { printf '✔ %s\n' "$1" >&2; }

current_branch() {
	git symbolic-ref --quiet --short HEAD 2>/dev/null || :
}

get_branch_name() {
	local branch
	branch="$(current_branch)"
	[[ -n ${branch} ]] || error "Cannot detect current branch (not a git repo or HEAD is detached)"

	printf '%s\n' "${branch}"
}

validate_prefix() {
	local branch=$1
	local type="${branch%%/*}"
	local allowed_list="${BRANCH_TYPES// /, }"

	for allowed in ${BRANCH_TYPES}; do
		[[ ${type} == "${allowed}" ]] && return 0
	done

	error "Branch must start with one of: ${allowed_list}"
}

detect_base() {
	local branch=$1
	local type="${branch%%/*}"

	case "${type}" in
	hotfix) echo main ;;
	*) echo develop ;;
	esac
}

ensure_local_branch_does_not_exist() {
	local branch=$1

	if git show-ref --verify --quiet "refs/heads/${branch}"; then
		error "Local branch '${branch}' already exists"
	fi
}

ensure_base_branch_exists() {
	local base=$1

	git show-ref --verify --quiet "refs/remotes/origin/${base}" ||
		error "Base branch 'origin/${base}' was not found"
}

ensure_remote_branch_does_not_exist() {
	local branch=$1

	if git show-ref --verify --quiet "refs/remotes/origin/${branch}"; then
		error "Remote branch '${branch}' already exists on origin"
	fi
}

get_worktree_status() {
	git status --porcelain=1 --untracked-files=normal
}

create_autostash() {
	local label=$1
	local stash_before stash_after

	stash_before=$(git rev-parse -q --verify refs/stash 2>/dev/null || true)

	info "Stashing local changes…"
	git stash push -u -m "${label}" >/dev/null || error "Failed to stash local changes"

	stash_after=$(git rev-parse -q --verify refs/stash 2>/dev/null || true)

	[[ -n ${stash_after} && ${stash_after} != "${stash_before}" ]] ||
		error "Expected an auto-stash to be created, but none was found"

	printf '%s\n' "${stash_after}"
}

restore_autostash() {
	local stash_ref=$1

	[[ -n ${stash_ref} ]] || return 0

	info "Restoring stashed local changes…"
	if git stash apply --index "${stash_ref}"; then
		git stash drop "${stash_ref}" >/dev/null 2>&1 || true
		info "Restored local changes"
		return 0
	fi

	warn "Auto-stash could not be restored cleanly."
	warn "Your stash was kept as '${stash_ref}'"
	warn "Re-apply it manually with: git stash apply --index ${stash_ref}"
	error "Failed to restore auto-stashed changes"
}

rollback_create() {
	local original_branch=$1
	local stash_ref=${2-}
	local returned_to_original=false

	warn "Branch creation failed. Attempting to restore previous state…"

	if [[ -n ${original_branch} ]]; then
		if git checkout "${original_branch}" >/dev/null 2>&1; then
			returned_to_original=true
			info "Returned to '${original_branch}'"
		else
			warn "Could not switch back to '${original_branch}'"
		fi
	else
		warn "Original context was detached HEAD; skipping automatic branch restore"
	fi

	if [[ -n ${stash_ref} ]]; then
		if ${returned_to_original}; then
			info "Restoring stashed local changes to '${original_branch}'…"
			if git stash apply --index "${stash_ref}" >/dev/null 2>&1; then
				git stash drop "${stash_ref}" >/dev/null 2>&1 || true
				info "Restored local changes to '${original_branch}'"
			else
				warn "Could not restore stashed changes automatically"
				warn "Your stash was kept as '${stash_ref}'"
			fi
		else
			warn "Your stash was kept as '${stash_ref}'"
		fi
	fi
}

fetch_prune() {
	info "Fetching and pruning origin…"
	git fetch --prune origin
}

conditional_push() {
	local branch=$1 do_push=$2 action=$3
	if ${do_push}; then
		info "Pushing '${branch}'…"
		git push --force-with-lease origin "${branch}" || error "Push failed for branch '${branch}'"
		ok "${action} and pushed '${branch}'"
	else
		ok "${action} '${branch}'"
	fi
}

# --- Commands ---
cmd_sync() {
	local do_push=false
	if [[ ${1-} == "--push" ]]; then
		do_push=true
		shift
	fi

	[[ $# -eq 0 ]] || error "Usage: git flow sync [--push]"

	local branch base
	branch=$(get_branch_name)
	validate_prefix "${branch}"
	base=$(detect_base "${branch}")

	echo "[GIT-FLOW] Syncing '${branch}' against '${base}'"
	fetch_prune

	info "Rebasing '${branch}' onto origin/${base}…"
	git rebase "origin/${base}" --autostash || error "Rebase failed; resolve conflicts and run 'git rebase --continue'"

	conditional_push "${branch}" "${do_push}" "Synced"
}

cmd_create() {
	local do_push=false type param target_branch
	local original_branch="" stash_ref="" worktree_status=""

	for arg in "$@"; do
		case "${arg}" in
		--push) do_push=true ;;
		*/*) target_branch="${arg}" ;;
		*) [[ -z ${type-} ]] && type="${arg}" || param="${arg}" ;;
		esac
	done

	if [[ -z ${target_branch-} ]]; then
		[[ -n ${type-} && -n ${param-} ]] || error "Usage: git flow {${BRANCH_TYPES// /|}} [--push] <name|type/name>"
		target_branch="${type}/${param}"
	fi

	validate_prefix "${target_branch}"

	local base
	base=$(detect_base "${target_branch}")
	original_branch="$(current_branch)"
	worktree_status="$(get_worktree_status)"

	echo "[GIT-FLOW] Creating '${target_branch}' from '${base}'"

	ensure_local_branch_does_not_exist "${target_branch}"

	fetch_prune

	ensure_base_branch_exists "${base}"
	ensure_remote_branch_does_not_exist "${target_branch}"

	if [[ -n ${worktree_status} ]]; then
		if [[ -n ${original_branch} ]]; then
			stash_ref=$(create_autostash "git-flow:auto-stash before creating ${target_branch} from ${original_branch}")
		else
			stash_ref=$(create_autostash "git-flow:auto-stash before creating ${target_branch}")
		fi
	fi

	if ! git checkout "${base}"; then
		rollback_create "${original_branch}" "${stash_ref}"
		error "Failed to checkout base branch '${base}'"
	fi

	if ! git merge --ff-only "origin/${base}"; then
		rollback_create "${original_branch}" "${stash_ref}"
		error "Failed to fast-forward '${base}' to 'origin/${base}'"
	fi

	if ! git checkout -b "${target_branch}"; then
		rollback_create "${original_branch}" "${stash_ref}"
		error "Failed to create branch '${target_branch}'"
	fi

	if [[ -n ${stash_ref} ]]; then
		restore_autostash "${stash_ref}"
	fi

	conditional_push "${target_branch}" "${do_push}" "Created"
}

cmd_propose_azure() {
	local branch base_url remote_url url target_ref

	branch=$(get_branch_name)
	echo "[GIT-FLOW] Generating PR creation URL for '${branch}'…"

	base_url=""
	if command -v az >/dev/null 2>&1 &&
		base_url=$(az repos show --detect --output tsv --query webUrl 2>/dev/null); then
		:
	fi

	if [[ -z ${base_url} ]]; then
		remote_url=$(git remote get-url origin 2>/dev/null) || error "Could not get remote URL from 'origin'"

		if [[ ${remote_url} =~ ^git@ssh\.dev\.azure\.com:v3/([^/]+)/([^/]+)/([^/]+)(\.git)?$ ]]; then
			base_url="https://dev.azure.com/${BASH_REMATCH[1]}/${BASH_REMATCH[2]}/_git/${BASH_REMATCH[3]}"
		elif [[ ${remote_url} =~ ^https://dev.azure.com/([^/]+)/([^/]+)/_git/([^/]+)(\.git)?$ ]]; then
			base_url="https://dev.azure.com/${BASH_REMATCH[1]}/${BASH_REMATCH[2]}/_git/${BASH_REMATCH[3]}"
		else
			error "Could not detect Azure DevOps repository from '${remote_url}'"
		fi
	fi

	target_ref=$(detect_base "${branch}")
	url="${base_url%/}/pullrequestcreate?sourceRef=${branch}&targetRef=${target_ref}"

	xdg-open "${url}" >/dev/null 2>&1 ||
		open "${url}" >/dev/null 2>&1 ||
		ok "Open this URL in your browser: ${url}"
}

# --- Dispatcher ---
cmd=${1-}
shift || true

case "${cmd}" in
--help)
	show_help
	;;
sync)
	cmd_sync "$@"
	;;
propose | pr)
	cmd_propose_azure
	;;
*)
	for type in ${BRANCH_TYPES}; do
		if [[ ${cmd} == "${type}" ]]; then
			cmd_create "${type}" "$@"
			exit
		elif [[ ${cmd} == "${type}/"* ]]; then
			cmd_create "${cmd}" "$@"
			exit
		fi
	done

	echo "Usage: git flow {sync,${BRANCH_TYPES// /,},propose} [args]"
	exit 1
	;;
esac
